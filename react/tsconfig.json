{
  "compilerOptions": {
    "alwaysStrict": true,
    "esModuleInterop": true,
    "jsx": "react",
    "lib": ["dom", "es2017", "es2018.promise"],
    "module": "esnext",
    "moduleResolution": "node",
    "skipLibCheck": true,
    "strict": true,
    "target": "es2017",
    "typeRoots": ["node_modules/@types"],
    "types": ["node"]
  },
  "include": ["./typings/*.d.ts", "./**/*.ts", "./**/*.tsx"],
  "exclude": ["node_modules"]
}
